# -------------------- Dependencies (prevent local OS‑specific modules) --------------------
node_modules/
package-lock.json   
yarn.lock
.pnpm-store/

# -------------------- Environment Variables (DO NOT bake secrets into the image) --------------------
.env
.env.*
!.env.example

# -------------------- Git & Version Control --------------------
.git/
.gitignore
.gitattributes
.gitmodules

# -------------------- Build Context Clutter --------------------
Dockerfile
.dockerignore
README.md
LICENSE
CHANGELOG.md

# -------------------- Logs & Temporary --------------------
logs/
*.log
tmp/
temp/
*.tmp

# -------------------- Test & Coverage --------------------
coverage/
.nyc_output/
__tests__/
tests/
*.test.js
*.spec.js
jest.config.js

# -------------------- OS & IDE --------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# -------------------- Misc Development --------------------
*.tgz
*.gz
*.zip
.ftpconfig
.remote-sync.json
.eslintcache
.stylelintcache
.node_repl_history